{
  "id": "full",
  "name": "Full Factory Run",
  "description": "Complete four-department pipeline with feedback loops and budget checkpoints.",
  "nodes": [
    {
      "id": "design",
      "runner": "departments/design/runner.js",
      "skipIf": "handoff/build-spec.md",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": [],
        "write": "design"
      }
    },
    {
      "id": "build",
      "runner": "departments/build/runner.js",
      "skipIf": "artifact/MANIFEST.txt",
      "feedbackLoop": true,
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "build"
      }
    },
    {
      "id": "review",
      "runner": "departments/review/runner.js",
      "skipIfEvent": "ship-approved",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "review"
      }
    },
    {
      "id": "security",
      "runner": "departments/security/runner.js",
      "skipIfEvent": "security-approved",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "security"
      }
    }
  ],
  "edges": [
    { "from": "design",   "to": "build",    "type": "forward",  "carries": ["design-spec", "runtime-spec", "factory-manifest"] },
    { "from": "build",    "to": "review",   "type": "forward",  "carries": ["build-artifact"] },
    { "from": "review",   "to": "security", "type": "forward",  "on": "ship-approved",         "carries": ["build-artifact"] },
    { "from": "review",   "to": "build",    "type": "backward", "on": "ship-rejected-no-ship", "carries": ["event:ship-rejected"],     "context": "failure-reports/" },
    { "from": "security", "to": "build",    "type": "backward", "on": "security-rejected",     "carries": ["event:security-rejected"], "context": "security-remediations/" }
  ],
  "budgetCheckpoints": ["after:build", "after:review", "after:security"]
}
