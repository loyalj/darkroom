{
  "id": "rapid",
  "name": "Rapid Prototype",
  "description": "Design and build only — skip review and security for fast iteration.",
  "orgProfile": "default",
  "nodes": [
    {
      "id": "design",
      "runner": "departments/design/runner.js",
      "manager": "ceo",
      "skipIf": "handoff/build-spec.md",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": [],
        "write": "design"
      }
    },
    {
      "id": "build",
      "runner": "departments/build/runner.js",
      "manager": "ceo",
      "skipIf": "artifact/MANIFEST.txt",
      "feedbackLoop": true,
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "build"
      }
    }
  ],
  "edges": [
    { "from": "design", "to": "build", "type": "forward", "carries": ["design-spec", "runtime-spec", "factory-manifest"] }
  ],
  "budgetCheckpoints": ["after:build"]
}
