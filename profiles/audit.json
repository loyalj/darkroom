{
  "id": "audit",
  "name": "Quality Audit",
  "description": "Review and security audit only — runs against existing build artifacts.",
  "requiresRun": true,
  "nodes": [
    {
      "id": "review",
      "runner": "departments/review/runner.js",
      "skipIf": "review/verdict-report.md",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "review"
      }
    },
    {
      "id": "security",
      "runner": "departments/security/runner.js",
      "skipIf": "security/security-verdict-report.md",
      "memory": {
        "readWiki": ["design", "build", "review", "security"],
        "readRuns": ["design", "build", "review", "security"],
        "write": "security"
      }
    }
  ],
  "edges": [
    { "from": "review", "to": "security", "type": "forward", "on": "ship-approved", "carries": ["build-artifact"] }
  ],
  "budgetCheckpoints": ["after:review", "after:security"]
}
